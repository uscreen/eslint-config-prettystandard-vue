{
  "name": "@uscreen.de/eslint-config-prettystandard-vue",
  "version": "0.3.14",
  "description": "ESLint sharable config: prettier & standard for vue",
  "main": "index.js",
  "homepage": "https://github.com/uscreen/eslint-config-prettystandard-vue",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uscreen/eslint-config-prettystandard-vue.git"
  },
  "author": "Marcus Spiegel <spiegel@uscreen.de>",
  "license": "MIT",
  "files": [
    "index.js"
  ],
  "scripts": {
    "test": "c8 tap",
    "test:cov": "c8 --reporter=html --reporter=text tap",
    "test:ci": "c8 --reporter=lcovonly tap",
    "lint": "eslint '**/*.js' --fix"
  },
  "keywords": [
    "eslint",
    "eslintconfig",
    "prettier",
    "standard",
    "vue"
  ],
  "dependencies": {
    "@vue/eslint-config-standard": "^8.0.1",
    "eslint": "^8.32.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-promise": "^7.0.0",
    "eslint-plugin-vue": "^9.9.0",
    "prettier": "^2.8.3",
    "vue-eslint-parser": "^10.1.1"
  },
  "devDependencies": {
    "c8": "^10.1.2",
    "tap": "^16.3.4"
  },
  "packageManager": "pnpm@10.21.0+sha512.da3337267e400fdd3d479a6c68079ac6db01d8ca4f67572083e722775a796788a7a9956613749e000fac20d424b594f7a791a5f4e2e13581c5ef947f26968a40"
}
